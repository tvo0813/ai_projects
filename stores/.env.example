# <Store Name> — local dev store config
# Usage: docker compose --env-file stores/<slug>.env -p <slug> up

STORE_SLUG=your-store-slug
STORE_NAME=Your Store Name
STORE_TAGLINE=Your store tagline here.
STORE_DOMAIN=yourdomain.com
GRAB_URL=https://food.grab.com/your-listing

OLLAMA_MODEL=llama3.2:1b

# Port offsets (allows running alongside other stores simultaneously)
# Phin and Beans: 5173 / 8000
# Phin Drips:     5174 / 8001
# Daboba:         5175 / 8002
FRONTEND_PORT=5176
BACKEND_PORT=8003
