crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.idea/
.vscode/
*.swp
*.swo
*.orig
Thumbs.db

